// API Configuration Template
// This file is automatically populated during deployment
// DO NOT edit this file directly - it will be overwritten

window.API_CONFIG = {
    // API Gateway URL from CloudFormation deployment
    // Automatically populated by deploy-app.sh script
    GATEWAY_URL: '{{API_GATEWAY_URL}}',
    
    // Endpoints (automatically constructed from GATEWAY_URL)
    get LIST_ENDPOINT() {
        return `${this.GATEWAY_URL}/list`;
    },
    get ANALYZE_ENDPOINT() {
        return `${this.GATEWAY_URL}/analyze`;
    },
    get CHAT_ENDPOINT() {
        return `${this.GATEWAY_URL}/chat`;
    },
    get CONFIG_ENDPOINT() {
        return `${this.GATEWAY_URL}/config`;
    },
    get ADMIN_CHECK_ENDPOINT() {
        return `${this.GATEWAY_URL}/config/admin-check`;
    },
    get OAUTH_TOKEN_ENDPOINT() {
        return `${this.GATEWAY_URL}/oauth/token`;
    },
    get DCR_REGISTER_ENDPOINT() {
        return `${this.GATEWAY_URL}/oauth/register`;
    }
};

// For development/testing, you can override with environment variable
if (typeof process !== 'undefined' && process.env.API_GATEWAY_URL) {
    API_CONFIG.GATEWAY_URL = process.env.API_GATEWAY_URL;
}

