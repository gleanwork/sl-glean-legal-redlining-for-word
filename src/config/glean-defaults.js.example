// Glean Default Configuration
// This file is automatically generated during deployment from prod.env values.
// DO NOT edit this file directly - it will be overwritten.
//
// Users can override these defaults in the Word Add-in Settings UI.

window.GLEAN_DEFAULTS = {
    // Glean instance name (e.g., "acme-corp" for acme-corp-be.glean.com)
    instance: '{{GLEAN_INSTANCE}}',
    
    // Authentication mode: 'cognito' or 'sso'
    authMode: '{{AUTH_MODE}}',
    
    // OAuth client type: 'dcr' (Dynamic Client Registration) or 'static'
    oauthClientType: '{{OAUTH_CLIENT_TYPE}}',
    
    // Glean OAuth Client ID (only used when oauthClientType is 'static')
    oauthClientId: '{{GLEAN_OAUTH_CLIENT_ID}}',
    
    // Agent IDs from your Glean instance
    chatAgentId: '{{CHAT_AGENT_ID}}',
    redlinerAgentId: '{{REDLINER_AGENT_ID}}',
    listingAgentId: '{{LISTING_AGENT_ID}}'
};

