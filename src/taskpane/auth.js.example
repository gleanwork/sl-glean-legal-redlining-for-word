/**
 * Authentication middleware for Glean Legal Add-in
 * Checks for valid JWT token and redirects to login if needed
 */

(function() {
    'use strict';
    
    // Skip auth check on login page and OAuth pages
    var skipPages = ['login.html', 'oauth-dialog.html', 'oauth-callback.html', 'admin.html'];
    var currentPath = window.location.pathname;
    for (var i = 0; i < skipPages.length; i++) {
        if (currentPath.includes(skipPages[i])) {
            console.log('Auth middleware: Skipping check on ' + skipPages[i]);
            return;
        }
    }
    
    // Detect auth mode from GLEAN_DEFAULTS (may not be loaded yet) or fallback
    function getAuthMode() {
        if (window.GLEAN_DEFAULTS && window.GLEAN_DEFAULTS.authMode) {
            return window.GLEAN_DEFAULTS.authMode;
        }
        // Check localStorage for cached auth mode indicator
        if (localStorage.getItem('glean_oauth_access_token')) {
            return 'sso';
        }
        return 'cognito';
    }
    
    // Wait for Office.js to be ready before checking auth
    // This prevents race conditions and ensures proper initialization
    if (typeof Office !== 'undefined') {
        Office.onReady(function(info) {
            console.log('Auth middleware: Office.js ready, checking authentication');
            // Small delay to ensure everything is loaded
            setTimeout(checkAuthentication, 100);
        });
    } else {
        // Fallback if Office.js is not available (shouldn't happen in add-in)
        console.log('Auth middleware: Office.js not available, checking authentication');
        checkAuthentication();
    }
    
    /**
     * Check if user is authenticated
     */
    function checkAuthentication() {
        // Prevent redirect loop - check if we just came from login
        var justLoggedIn = sessionStorage.getItem('just_logged_in');
        if (justLoggedIn === 'true') {
            console.log('Auth middleware: Just logged in, clearing flag');
            sessionStorage.removeItem('just_logged_in');
            // Don't check auth immediately after login
            setupTokenRefresh();
            return true;
        }
        
        var authMode = getAuthMode();
        console.log('Auth middleware: Checking authentication, mode=' + authMode);
        
        if (authMode === 'sso') {
            // SSO mode: check OAuth tokens
            var oauthToken = localStorage.getItem('glean_oauth_access_token');
            var oauthExpiry = parseInt(localStorage.getItem('glean_oauth_token_expiry') || '0');
            
            if (oauthToken && Date.now() < oauthExpiry) {
                console.log('Auth middleware: Valid OAuth token found');
                setupTokenRefresh();
                return true;
            }
            
            console.log('Auth middleware: No valid OAuth token, redirecting to login');
            window.location.replace('/taskpane/login.html');
            return false;
        } else {
            // Cognito mode: check Cognito tokens
            var token = getAuthToken();
            console.log('Auth middleware: Checking authentication', { hasToken: !!token });
            
            if (!token || !isTokenValid(token)) {
                console.log('Auth middleware: No valid token, redirecting to login');
                window.location.replace('/taskpane/login.html');
                return false;
            }
            
            console.log('Auth middleware: Valid token found');
            setupTokenRefresh();
            return true;
        }
    }
    
    /**
     * Get stored authentication token
     */
    function getAuthToken() {
        return localStorage.getItem('glean_auth_token');
    }
    
    /**
     * Check if token is still valid
     * Uses the same validation logic as login.js for consistency
     */
    function isTokenValid(token) {
        if (!token) {
            console.log('Auth middleware: No token provided');
            return false;
        }
        
        try {
            // Use stored expiry time (same as login.js)
            const expiresAt = parseInt(localStorage.getItem('glean_token_expires_at') || '0');
            const now = Date.now();
            
            console.log('Auth middleware: Token expiry check', {
                expiresAt: new Date(expiresAt).toISOString(),
                now: new Date(now).toISOString(),
                valid: expiresAt > (now + 5 * 60 * 1000)
            });
            
            // Token is valid if it expires more than 5 minutes from now
            return expiresAt > (now + 5 * 60 * 1000);
        } catch (error) {
            console.error('Auth middleware: Error validating token:', error);
            return false;
        }
    }
    
    /**
     * Set up automatic token refresh
     */
    function setupTokenRefresh() {
        var authMode = getAuthMode();
        
        if (authMode === 'sso') {
            // SSO mode: schedule OAuth token refresh at 80% TTL
            var oauthExpiry = parseInt(localStorage.getItem('glean_oauth_token_expiry') || '0');
            var now = Date.now();
            var ttl = oauthExpiry - now;
            
            if (ttl > 0) {
                var refreshDelay = Math.max(ttl * 0.8, 10000);
                console.log('Auth middleware: Scheduling OAuth refresh in ' + Math.round(refreshDelay / 1000) + 's');
                setTimeout(refreshOAuthToken, refreshDelay);
            }
            return;
        }
        
        // Cognito mode
        var token = getAuthToken();
        if (!token) return;
        
        try {
            var payload = JSON.parse(atob(token.split('.')[1]));
            var expiresAt = payload.exp * 1000;
            var now2 = Date.now();
            var timeUntilExpiry = expiresAt - now2;
            
            // Refresh token 5 minutes before expiry
            var refreshTime = timeUntilExpiry - (5 * 60 * 1000);
            
            if (refreshTime > 0) {
                setTimeout(refreshAuthToken, refreshTime);
            }
        } catch (error) {
            console.error('Error setting up token refresh:', error);
        }
    }
    
    /**
     * Refresh OAuth token using refresh_token grant (SSO mode)
     */
    async function refreshOAuthToken() {
        var refreshToken = localStorage.getItem('glean_oauth_refresh_token');
        if (!refreshToken) {
            console.log('Auth middleware: No OAuth refresh token, redirecting to login');
            window.location.href = '/taskpane/login.html';
            return;
        }
        
        try {
            // Dynamic import of gleanOAuth for token refresh
            var gleanOAuthModule = await import('../services/gleanOAuth.js');
            var gleanOAuth = gleanOAuthModule.gleanOAuth;
            
            await gleanOAuth.refreshAccessToken();
            console.log('Auth middleware: OAuth token refreshed successfully');
            setupTokenRefresh();
        } catch (error) {
            console.error('Auth middleware: OAuth refresh failed:', error);
            window.location.href = '/taskpane/login.html';
        }
    }
    
    /**
     * Refresh authentication token using Cognito refresh token
     */
    async function refreshAuthToken() {
        const refreshToken = localStorage.getItem('glean_refresh_token');
        
        if (!refreshToken) {
            console.log('Token refresh: No refresh token available, redirecting to login');
            window.location.href = '/taskpane/login.html';
            return;
        }
        
        console.log('Token refresh: Attempting to refresh token with Cognito');
        
        try {
            // Initialize Cognito client
            const cognitoIdentityServiceProvider = new AWS.CognitoIdentityServiceProvider({
                region: 'us-east-1'
            });
            
            const params = {
                AuthFlow: 'REFRESH_TOKEN_AUTH',
                ClientId: '{{CLIENT_ID}}',
                AuthParameters: {
                    REFRESH_TOKEN: refreshToken
                }
            };
            
            const response = await cognitoIdentityServiceProvider.initiateAuth(params).promise();
            
            // Decode the new ID token to get expiration
            const idTokenPayload = JSON.parse(atob(response.AuthenticationResult.IdToken.split('.')[1]));
            const expiresAt = idTokenPayload.exp * 1000;
            
            // Store new tokens
            localStorage.setItem('glean_auth_token', response.AuthenticationResult.IdToken);
            localStorage.setItem('glean_access_token', response.AuthenticationResult.AccessToken);
            localStorage.setItem('glean_token_expires_at', expiresAt.toString());
            
            // Update cookie
            const expiryDate = new Date(expiresAt);
            document.cookie = `glean_auth_token=${response.AuthenticationResult.IdToken}; path=/; expires=${expiryDate.toUTCString()}; secure; samesite=none`;
            
            console.log('Token refresh: Successfully refreshed token', {
                expiresAt: new Date(expiresAt).toISOString()
            });
            
            // Set up next refresh
            setupTokenRefresh();
            
        } catch (error) {
            console.error('Token refresh: Error refreshing token:', error);
            // If refresh fails, redirect to login
            window.location.href = '/taskpane/login.html';
        }
    }
    
    /**
     * Get current user info from token
     */
    window.getCurrentUser = function() {
        var authMode = getAuthMode();
        var token;
        
        if (authMode === 'sso') {
            token = localStorage.getItem('glean_oauth_access_token') || localStorage.getItem('glean_oauth_id_token');
        } else {
            token = getAuthToken();
        }
        
        if (!token) return null;
        
        try {
            var payload = JSON.parse(atob(token.split('.')[1]));
            return {
                email: payload.email || payload.preferred_username,
                sub: payload.sub,
                exp: payload.exp,
                authMode: authMode
            };
        } catch (error) {
            console.error('Error getting user info:', error);
            return null;
        }
    };
    
    /**
     * Logout function
     */
    window.logout = function() {
        console.log('Logging out...');
        
        // Clear Cognito tokens
        localStorage.removeItem('glean_auth_token');
        localStorage.removeItem('glean_access_token');
        localStorage.removeItem('glean_refresh_token');
        localStorage.removeItem('glean_token_expires_at');
        
        // Clear OAuth tokens
        localStorage.removeItem('glean_oauth_access_token');
        localStorage.removeItem('glean_oauth_refresh_token');
        localStorage.removeItem('glean_oauth_token_expiry');
        localStorage.removeItem('glean_oauth_id_token');
        
        // Clear sessionStorage
        sessionStorage.clear();
        
        // Clear the authentication cookie
        document.cookie = 'glean_auth_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; secure; samesite=none';
        
        console.log('Logout complete, redirecting to login');
        window.location.href = '/taskpane/login.html';
    };
    
    // Export auth check function
    window.isAuthenticated = checkAuthentication;
    
})();
