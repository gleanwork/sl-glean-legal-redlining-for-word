# Local Development Configuration (local web server, not an AWS stack)
# Used for running the add-in against a local server. For the deployed AWS
# dev stack, see dev.env instead.

# AWS Configuration (not used for local dev)
AWS_PROFILE=your-aws-profile-name
AWS_REGION=us-east-1

# Application Configuration
BASE_PATH="/taskpane"
LOGIN_URL="/taskpane/login.html"
API_BASE_URL="http://localhost:3000"

# Local Development
LOCAL_PORT=8081
LOCAL_HOST=localhost
