# Production Environment Configuration
# Copy this file to prod.env and fill in your actual values

# AWS Configuration
AWS_PROFILE=your-aws-profile-name
AWS_REGION=us-east-1

# CloudFormation Stack
STACK_NAME=glean-legal-addin
DEPLOYMENT_ID=prod

# Domain and Certificate
# Create ACM certificate in us-east-1 region BEFORE deployment
DOMAIN_NAME=your-domain.example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID

# Authentication Mode
# Options: "cognito" (username/password) or "sso" (Glean OAuth)
# - cognito: Users sign in with Cognito credentials (simpler, good for demos/POCs)
# - sso: Users sign in via their organization's SSO through Glean OAuth (recommended for production)
AUTH_MODE=cognito

# SSO Configuration (only used when AUTH_MODE=sso)
#
# OAuth Client Type: "dcr" (Dynamic Client Registration) or "static"
# - dcr (default, recommended): Registers a public OAuth client automatically with Glean.
#   All users receive full scopes (agents, chat, search) regardless of Glean admin roles.
#   No client secret needed. Set GLEAN_OAUTH_CLIENT_ID and GLEAN_OAUTH_CLIENT_SECRET to empty.
# - static: Use a pre-registered OAuth client from Glean Admin Console.
#   Requires GLEAN_OAUTH_CLIENT_ID and GLEAN_OAUTH_CLIENT_SECRET.
#   Note: Only users with "Agents admin" role will receive the agents scope.
OAUTH_CLIENT_TYPE=dcr

# Static OAuth client settings (only used when OAUTH_CLIENT_TYPE=static)
# Register in Glean Admin Console → Settings → Third-party access (OAuth)
# Set redirect URI to: https://<your-domain>/taskpane/oauth-callback.html
# Request scopes: agents chat search
GLEAN_OAUTH_CLIENT_ID=
GLEAN_OAUTH_CLIENT_SECRET=

# Admin Configuration
# Comma-separated list of admin emails for initial seeding.
# These users can manage config via the admin page after deployment.
# Only used on first deploy (or with --force-seed). After that, admins are managed via the admin page.
ADMIN_EMAILS=admin@example.com

# Cognito User Configuration (only used when AUTH_MODE=cognito)
# ⚠️  CRITICAL: Set BOTH email and password BEFORE first deployment!
# 
# The Cognito user is created automatically during stack deployment via Custom Resource.
# If password is empty during first deployment, no user will be created and you'll need
# to create it manually using: aws cognito-idp admin-create-user
#
# This will be the admin user for accessing the Word Add-in.
# Password requirements: minimum 8 characters with uppercase, lowercase, number, and special character
#
# Example: COGNITO_USER_EMAIL=yourname@yourdomain.com
# Example: COGNITO_USER_PASSWORD=MySecure123!Pass
COGNITO_USER_EMAIL=admin@example.com
COGNITO_USER_PASSWORD=ChangeMe123!@#

# Glean Configuration
# These values will be injected as defaults in the Word Add-in.
# Users can override them in the Settings UI if needed.
# Only the API Token must be entered manually by each user.
#
# GLEAN_INSTANCE: Your Glean instance name (e.g., "acme-corp" for acme-corp-be.glean.com)
# Agent IDs: Copy from your Glean instance after creating each agent
GLEAN_INSTANCE=your-instance-name
CHAT_AGENT_ID=
REDLINER_AGENT_ID=
LISTING_AGENT_ID=

# S3 Bucket (will be retrieved from CloudFormation outputs)
# BUCKET_NAME will be set dynamically

# CloudFront Distribution (will be retrieved from CloudFormation outputs)
# DISTRIBUTION_ID will be set dynamically

# Deployment Options
CACHE_CONTROL_HTML="max-age=300"
CACHE_CONTROL_JS="max-age=300"
CACHE_CONTROL_CSS="max-age=300"
CACHE_CONTROL_ASSETS="max-age=86400"
