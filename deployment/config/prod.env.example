# Production Environment Configuration
# Copy this file to prod.env and fill in your actual values.
#
# Recommended production authentication:
#   AUTH_MODE=sso
#   OAUTH_CLIENT_TYPE=dcr
#
# In SSO/DCR mode, users sign in with Glean and do NOT enter personal Glean API tokens.

# AWS Configuration
AWS_PROFILE=your-aws-profile-name
AWS_REGION=us-east-1

# CloudFormation Stack
STACK_NAME=glean-legal-addin
DEPLOYMENT_ID=prod

# Domain and Certificate
# Create an ACM certificate in us-east-1 BEFORE deployment.
DOMAIN_NAME=redlining.example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID

# Authentication Mode
# Options:
# - sso: Recommended for production. Users sign in with Glean OAuth.
# - cognito: Optional demo/POC mode. Users sign in with Cognito and must provide a Glean API token.
AUTH_MODE=sso

# SSO Configuration
#
# OAuth Client Type:
# - dcr: Recommended. Dynamically registers a public OAuth client with Glean.
#        No static client ID or client secret is needed.
# - static: Use a pre-registered OAuth client from Glean Admin Console.
#           Requires GLEAN_OAUTH_CLIENT_ID and GLEAN_OAUTH_CLIENT_SECRET.
OAUTH_CLIENT_TYPE=dcr

# Static OAuth client settings (only used when OAUTH_CLIENT_TYPE=static)
# Register in Glean Admin Console -> Settings -> Third-party access (OAuth)
# Redirect URI: https://<your-domain>/taskpane/oauth-callback.html
# Requested scopes: agents chat search
#
# Leave these blank for OAUTH_CLIENT_TYPE=dcr.
GLEAN_OAUTH_CLIENT_ID=
GLEAN_OAUTH_CLIENT_SECRET=

# Admin Configuration
# Comma-separated list of admin emails for initial seeding.
# These users can manage org-level config via the add-in after deployment.
# Only used on first deploy, unless deploy-app.sh is run with --force-seed.
ADMIN_EMAILS=admin@example.com

# Cognito User Configuration (only used when AUTH_MODE=cognito)
#
# Cognito mode is intended for demos/POCs or isolated test environments.
# In Cognito mode, users sign in with Cognito credentials and must enter a Glean API token
# in the add-in settings.
#
# If AUTH_MODE=sso, these values are ignored.
COGNITO_USER_EMAIL=admin@example.com
COGNITO_USER_PASSWORD=ChangeMe123!@#

# Glean Configuration
# These values are injected as org defaults for the add-in.
# They can also be managed later from the add-in's admin configuration UI.
#
# GLEAN_INSTANCE: Your Glean instance name (e.g., "acme-corp" for acme-corp-be.glean.com)
# Agent IDs: Copy from your Glean instance after creating each agent.
GLEAN_INSTANCE=your-instance-name
CHAT_AGENT_ID=
REDLINER_AGENT_ID=
LISTING_AGENT_ID=

# S3 Bucket (retrieved from CloudFormation outputs)
# BUCKET_NAME is set dynamically by deployment scripts.

# CloudFront Distribution (retrieved from CloudFormation outputs)
# DISTRIBUTION_ID is set dynamically by deployment scripts.

# Deployment Options
CACHE_CONTROL_HTML="max-age=300"
CACHE_CONTROL_JS="max-age=300"
CACHE_CONTROL_CSS="max-age=300"
CACHE_CONTROL_ASSETS="max-age=86400"
